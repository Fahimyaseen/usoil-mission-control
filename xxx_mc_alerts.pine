// Alert System for XXX + Master Coach
// ADD THIS AS A SEPARATE INDICATOR - Does not replace XXX_v6

//@version=5
indicator("XXX+MC Alert System", overlay=false)

// Master Coach Inputs
mfiLength = input.int(14, "MFI Length", minval=5)
rsiLength = input.int(14, "RSI Length", minval=5)
htfTimeframe = input.timeframe("15", "HTF Trend Filter")
volSMA_len = input.int(20, "Volume SMA Length")
structLen = input.int(5, "Structure Lookback", minval=2)
minGrade = input.int(4, "Min Grade for Signal (1-6)", minval=1, maxval=6)

// Get XXX signals from chart (assumes XXX is already on chart)
// We'll detect if there's an active long/short signal

// Master Coach Logic
var float lastHigh = na
var float lastLow = na
var int structure = 0

pH = ta.pivothigh(high, structLen, structLen)
pL = ta.pivotlow(low, structLen, structLen)

if not na(pH)
    lastHigh := pH
if not na(pL)
    lastLow := pL

if close > lastHigh
    structure := 1
else if close < lastLow
    structure := -1

structBull = structure == 1

// Core indicators
mfiVal = ta.mfi(close, mfiLength)
mfiBull = mfiVal > 50
htfEMA = request.security(syminfo.tickerid, htfTimeframe, ta.ema(close, 50), lookahead=barmerge.lookahead_off)
htfBull = close > htfEMA
rsiVal = ta.rsi(close, rsiLength)
rsiBull = rsiVal > 50
volSMA = ta.sma(volume, volSMA_len)
volBull = volume > volSMA

// Grading
int bullGrade = (mfiBull ? 1 : 0) + (htfBull ? 1 : 0) + (rsiBull ? 1 : 0) + (volBull ? 1 : 0) + (structBull ? 1 : 0)
int bearGrade = (not mfiBull ? 1 : 0) + (not htfBull ? 1 : 0) + (not rsiBull ? 1 : 0) + (volBull ? 1 : 0) + (not structBull ? 1 : 0)

mcBull = bullGrade >= minGrade
mcBear = bearGrade >= minGrade

// Simple entry detection (you manually confirm with XXX)
longSignal = ta.crossover(close, ta.ema(close, 2)) and mcBull
shortSignal = ta.crossunder(close, ta.ema(close, 2)) and mcBear

// Plot signals
plotshape(longSignal, title="MC Long OK", location=location.top, color=color.green, style=shape.triangleup, text="L")
plotshape(shortSignal, title="MC Short OK", location=location.top, color=color.red, style=shape.triangledown, text="S")

// Background color
bgcolor(longSignal ? color.new(color.green, 90) : shortSignal ? color.new(color.red, 90) : na)

// Alerts
alertcondition(longSignal, title="Long - MC Grade OK", message="Master Coach Grade >= {{minGrade}}. Check XXX for entry signal.")
alertcondition(shortSignal, title="Short - MC Grade OK", message="Master Coach Grade >= {{minGrade}}. Check XXX for entry signal.")

// Dashboard
var table dash = table.new(position.middle_right, 2, 6, bgcolor=color.new(color.black, 10))

if barstate.islast
    table.cell(dash, 0, 0, "MC GRADE", text_color=color.white, bgcolor=color.purple)
    table.merge_cells(dash, 0, 0, 1, 0)
    
    table.cell(dash, 0, 1, "Bull Grade", text_color=color.white)
    table.cell(dash, 1, 1, str.tostring(bullGrade) + "/6", text_color=bullGrade >= minGrade ? color.green : color.gray)
    
    table.cell(dash, 0, 2, "Bear Grade", text_color=color.white)
    table.cell(dash, 1, 2, str.tostring(bearGrade) + "/6", text_color=bearGrade >= minGrade ? color.red : color.gray)
    
    table.cell(dash, 0, 3, "Structure", text_color=color.white)
    table.cell(dash, 1, 3, structBull ? "BULL" : "BEAR", text_color=structBull ? color.green : color.red)
    
    table.cell(dash, 0, 4, "MFI", text_color=color.white)
    table.cell(dash, 1, 4, mfiBull ? "INFLOW" : "OUTFLOW", text_color=mfiBull ? color.green : color.red)
    
    table.cell(dash, 0, 5, "RSI", text_color=color.white)
    table.cell(dash, 1, 5, str.tostring(rsiVal, "#."), text_color=rsiBull ? color.green : color.red)
