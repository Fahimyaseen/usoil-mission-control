// Complete MC+XXX Fusion with Supply/Demand Zones

//@version=6
strategy(
 'MC+XXX Pro',
 shorttitle = 'MC+XXX Pro',
 overlay = true,
 explicit_plot_zorder = true,
 pyramiding = 0,
 default_qty_type = strategy.percent_of_equity,
 default_qty_value = 10,
 calc_on_every_tick = false,
 process_orders_on_close = true,
 initial_capital = 10000)

// === GROUPS ===
G_MC = 'Master Coach'
G_XXX = 'XXX Indicator'
G_SD = 'Supply/Demand Zones'
G_RISK = 'Risk Management'

// ============================================
// MASTER COACH LOGIC
// ============================================
mfiLength = input.int(14, "MFI Length", minval=5, group=G_MC)
rsiLength = input.int(14, "RSI Length", minval=5, group=G_MC)
htfTimeframe = input.timeframe("15", "HTF Trend", group=G_MC)
volSMA_len = input.int(20, "Volume SMA", group=G_MC)
structLen = input.int(5, "Structure Lookback", minval=2, group=G_MC)
minGrade = input.int(4, "Min Grade for Signal", minval=1, maxval=6, group=G_MC)

// Market Structure
var float lastHigh = na
var float lastLow = na
var int structure = 0

pH = ta.pivothigh(high, structLen, structLen)
pL = ta.pivotlow(low, structLen, structLen)

if not na(pH)
    lastHigh := pH
if not na(pL)
    lastLow := pL

if close > lastHigh
    structure := 1
else if close < lastLow
    structure := -1

structBull = structure == 1

// Core Indicators
mfiVal = ta.mfi(close, mfiLength)
mfiBull = mfiVal > 50
htfEMA = request.security(syminfo.tickerid, htfTimeframe, ta.ema(close, 50), lookahead=barmerge.lookahead_off)
htfBull = close > htfEMA
rsiVal = ta.rsi(close, rsiLength)
rsiBull = rsiVal > 50
volSMA = ta.sma(volume, volSMA_len)
volBull = volume > volSMA
atr = ta.atr(14)
volatilityOk = atr > ta.sma(atr, 50)

// Grading
int bullGrade = (mfiBull ? 1 : 0) + (htfBull ? 1 : 0) + (rsiBull ? 1 : 0) + (volBull ? 1 : 0) + (volatilityOk ? 1 : 0) + (structBull ? 1 : 0)
int bearGrade = (not mfiBull ? 1 : 0) + (not htfBull ? 1 : 0) + (not rsiBull ? 1 : 0) + (volBull ? 1 : 0) + (volatilityOk ? 1 : 0) + (not structBull ? 1 : 0)

mcBull = bullGrade >= minGrade
mcBear = bearGrade >= minGrade

// ============================================
// XXX INDICATOR (ALMA)
// ============================================
basisLen = input.int(2, 'MA Period', minval=1, group=G_XXX)
offsetSigma = input.int(5, 'Sigma', minval=0, group=G_XXX)
offsetALMA = input.float(0.85, 'Offset', minval=0, step=0.01, group=G_XXX)

// ALMA
alma(src, len, offset, sigma) =>
    m = offset * (len - 1)
    s = len / sigma
    sum = 0.0
    norm = 0.0
    for i = 0 to len - 1
        weight = math.exp(-math.pow(i - m, 2) / (2 * math.pow(s, 2)))
        sum += nz(src[i]) * weight
        norm += weight
    norm != 0 ? sum / norm : na

basis = alma(close, basisLen, offsetALMA, offsetSigma)

// ============================================
// SUPPLY/DEMAND ZONES
// ============================================
swingLen = input.int(10, 'Swing Lookback', minval=1, group=G_SD)
boxWidth = input.float(2.5, 'Zone Width', minval=0.5, maxval=10, step=0.5, group=G_SD)
showZones = input.bool(true, 'Show S/D Zones', group=G_SD)

// Arrays for zones
var box[] supplyBoxes = array.new_box(20)
var box[] demandBoxes = array.new_box(20)

// Swing detection
swingHigh = ta.pivothigh(high, swingLen, swingLen)
swingLow = ta.pivotlow(low, swingLen, swingLen)

// Draw Supply Zone (on swing high)
if not na(swingHigh) and showZones
    box_top = swingHigh
    box_bottom = swingHigh - (atr * boxWidth / 10)
    boxRight = bar_index + 20
    
    // Delete oldest, add new
    if array.size(supplyBoxes) >= 20
        box.delete(array.shift(supplyBoxes))
    
    newBox = box.new(bar_index - swingLen, box_top, boxRight, box_bottom, 
                     border_color=color.red, bgcolor=color.new(color.red, 85),
                     extend=extend.right, text="SUPPLY", text_color=color.white,
                     text_size=size.tiny, xloc=xloc.bar_index)
    array.push(supplyBoxes, newBox)

// Draw Demand Zone (on swing low)
if not na(swingLow) and showZones
    box_bottom = swingLow
    box_top = swingLow + (atr * boxWidth / 10)
    boxRight = bar_index + 20
    
    // Delete oldest, add new
    if array.size(demandBoxes) >= 20
        box.delete(array.shift(demandBoxes))
    
    newBox = box.new(bar_index - swingLen, box_top, boxRight, box_bottom,
                     border_color=color.green, bgcolor=color.new(color.green, 85),
                     extend=extend.right, text="DEMAND", text_color=color.white,
                     text_size=size.tiny, xloc=xloc.bar_index)
    array.push(demandBoxes, newBox)

// ============================================
// SIGNAL LOGIC
// ============================================
longSignal = ta.crossover(close, basis) and mcBull
shortSignal = ta.crossunder(close, basis) and mcBear

// ============================================
// RISK MANAGEMENT
// ============================================
atrSLMult = input.float(1.5, "SL ATR Mult", step=0.1, group=G_RISK)
atrTP1Mult = input.float(1.0, "TP1 ATR Mult", step=0.1, group=G_RISK)
atrTP2Mult = input.float(2.0, "TP2 ATR Mult", step=0.1, group=G_RISK)
atrTP3Mult = input.float(3.0, "TP3 ATR Mult", step=0.1, group=G_RISK)

longSL = close - (atr * atrSLMult)
longTP1 = close + (atr * atrTP1Mult)
longTP2 = close + (atr * atrTP2Mult)
longTP3 = close + (atr * atrTP3Mult)

shortSL = close + (atr * atrSLMult)
shortTP1 = close - (atr * atrTP1Mult)
shortTP2 = close - (atr * atrTP2Mult)
shortTP3 = close - (atr * atrTP3Mult)

// ============================================
// STRATEGY EXECUTION
// ============================================
inLong = strategy.position_size > 0
inShort = strategy.position_size < 0

if longSignal and not inLong and not inShort
    strategy.entry("Long", strategy.long)
    strategy.exit("Long Exit", "Long", stop=longSL, limit=longTP3)

if shortSignal and not inShort and not inLong
    strategy.entry("Short", strategy.short)
    strategy.exit("Short Exit", "Short", stop=shortSL, limit=shortTP3)

// ============================================
// PLOTTING
// ============================================
plot(basis, "ALMA", color=color.orange, linewidth=2)

plotshape(longSignal, title="Long", location=location.belowbar, 
          color=color.green, style=shape.triangleup, size=size.normal, text="L")
plotshape(shortSignal, title="Short", location=location.abovebar,
          color=color.red, style=shape.triangledown, size=size.normal, text="S")

bgcolor(longSignal ? color.new(color.green, 90) : shortSignal ? color.new(color.red, 90) : na)

// ============================================
// DASHBOARD
// ============================================
var table dash = table.new("top_right", 2, 9, frame_color=color.gray, bgcolor=color.new(color.black, 10))

if barstate.islast
    table.cell(dash, 0, 0, "MC+XXX PRO", text_color=color.white, bgcolor=color.purple)
    table.merge_cells(dash, 0, 0, 1, 0)
    
    sigText = longSignal ? "🟢 LONG" : shortSignal ? "🔴 SHORT" : "⏳ WAIT"
    sigCol = longSignal ? color.green : shortSignal ? color.red : color.gray
    
    table.cell(dash, 0, 1, "Signal", text_color=color.white)
    table.cell(dash, 1, 1, sigText, text_color=sigCol)
    
    table.cell(dash, 0, 2, "Grade", text_color=color.white)
    table.cell(dash, 1, 2, mcBull ? str.tostring(bullGrade)+"/6" : mcBear ? str.tostring(bearGrade)+"/6" : "-",
               text_color=mcBull ? color.green : mcBear ? color.red : color.gray)
    
    table.cell(dash, 0, 3, "Structure", text_color=color.white)
    table.cell(dash, 1, 3, structBull ? "BULL" : "BEAR", 
               text_color=structBull ? color.green : color.red)
    
    table.cell(dash, 0, 4, "MFI", text_color=color.white)
    table.cell(dash, 1, 4, mfiBull ? "IN" : "OUT",
               text_color=mfiBull ? color.green : color.red)
    
    table.cell(dash, 0, 5, "RSI", text_color=color.white)
    table.cell(dash, 1, 5, str.tostring(rsiVal, "#."),
               text_color=rsiBull ? color.green : color.red)
    
    table.cell(dash, 0, 6, "Entry", text_color=color.white)
    table.cell(dash, 1, 6, str.tostring(close, format.mintick), text_color=color.yellow)
    
    table.cell(dash, 0, 7, "SL", text_color=color.white)
    table.cell(dash, 1, 7, str.tostring(longSignal ? longSL : shortSL, format.mintick), text_color=color.red)
    
    table.cell(dash, 0, 8, "TP3", text_color=color.white)
    table.cell(dash, 1, 8, str.tostring(longSignal ? longTP3 : shortTP3, format.mintick), text_color=color.green)

// ============================================
// ALERTS
// ============================================
alertLong = "🛢️ USOIL LONG\nEntry: " + str.tostring(close, format.mintick) +
            "\nSL: " + str.tostring(longSL, format.mintick) +
            "\nTP: " + str.tostring(longTP3, format.mintick) +
            "\nGrade: " + str.tostring(bullGrade) + "/6"

alertShort = "🛢️ USOIL SHORT\nEntry: " + str.tostring(close, format.mintick) +
             "\nSL: " + str.tostring(shortSL, format.mintick) +
             "\nTP: " + str.tostring(shortTP3, format.mintick) +
             "\nGrade: " + str.tostring(bearGrade) + "/6"

alertcondition(longSignal, title="🟢 Long", message=alertLong)
alertcondition(shortSignal, title="🔴 Short", message=alertShort)

if longSignal
    alert(alertLong, alert.freq_once_per_bar_close)
if shortSignal
    alert(alertShort, alert.freq_once_per_bar_close)
