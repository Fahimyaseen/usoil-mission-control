// Merged Strategy: Master Coach + XXX_v6 with Alerts

//@version=6
strategy(
 'Master Coach + XXX Fusion',
 shorttitle = 'MC+XXX Fusion',
 overlay = true,
 explicit_plot_zorder = true,
 pyramiding = 0,
 default_qty_type = strategy.percent_of_equity,
 default_qty_value = 10,
 calc_on_every_tick = false,
 process_orders_on_close = true,
 initial_capital = 10000)

// === GROUPS ===
G_MC = 'Master Coach Settings'
G_XXX = 'XXX Indicator Settings'
G_ALERTS = 'Alert Settings'
G_RISK = 'Risk Management'

// ============================================
// MASTER COACH LOGIC
// ============================================
mfiLength = input.int(14, "MFI Length", minval = 5, group = G_MC)
rsiLength = input.int(14, "RSI Length", minval = 5, group = G_MC)
htfTimeframe = input.timeframe("15", "HTF Trend Filter", group = G_MC)
volSMA_len = input.int(20, "Volume SMA Length", group = G_MC)
structLen = input.int(5, "Structure Lookback", minval = 2, group = G_MC)
minGrade = input.int(4, "Min Grade for Signal (1-6)", minval = 1, maxval = 6, group = G_MC)

// Market Structure
var float lastHigh = na
var float lastLow = na
var int structure = 0

pH = ta.pivothigh(high, structLen, structLen)
pL = ta.pivotlow(low, structLen, structLen)

if not na(pH)
    lastHigh := pH
if not na(pL)
    lastLow := pL

if close > lastHigh
    structure := 1
else if close < lastLow
    structure := -1

structBull = structure == 1

// Core Indicators
mfiVal = ta.mfi(close, mfiLength)
mfiBull = mfiVal > 50
htfEMA = request.security(syminfo.tickerid, htfTimeframe, ta.ema(close, 50), lookahead = barmerge.lookahead_off)
htfBull = close > htfEMA
rsiVal = ta.rsi(close, rsiLength)
rsiBull = rsiVal > 50
volSMA = ta.sma(volume, volSMA_len)
volBull = volume > volSMA
atr = ta.atr(14)
volatilityOk = atr > ta.sma(atr, 50)

// Grading
int bullGrade = (mfiBull ? 1 : 0) + (htfBull ? 1 : 0) + (rsiBull ? 1 : 0) + (volBull ? 1 : 0) + (volatilityOk ? 1 : 0) + (structBull ? 1 : 0)
int bearGrade = (not mfiBull ? 1 : 0) + (not htfBull ? 1 : 0) + (not rsiBull ? 1 : 0) + (volBull ? 1 : 0) + (volatilityOk ? 1 : 0) + (not structBull ? 1 : 0)

mcBull = bullGrade >= minGrade
mcBear = bearGrade >= minGrade

// ============================================
// XXX INDICATOR LOGIC (Simplified)
// ============================================
basisType = input.string('ALMA', 'MA Type', options=['TEMA', 'HullMA', 'ALMA'], group = G_XXX)
basisLen = input.int(2, 'MA Period', minval=1, group = G_XXX)
offsetSigma = input.int(5, 'Sigma for ALMA', minval=0, group = G_XXX)
offsetALMA = input.float(0.85, 'Offset for ALMA', minval=0, step=0.01, group = G_XXX)

// ALMA Calculation
alma(src, len, offset, sigma) =>
    m = offset * (len - 1)
    s = len / sigma
    w = math.exp(-math.pow(math.abs(na(src) ? 0 : src - m), 2) / (2 * math.pow(s, 2)))
    sum = 0.0
    norm = 0.0
    for i = 0 to len - 1
        weight = math.exp(-math.pow(i - m, 2) / (2 * math.pow(s, 2)))
        sum := sum + nz(src[i]) * weight
        norm := norm + weight
    norm != 0 ? sum / norm : na

basis = basisType == 'ALMA' ? alma(close, basisLen, offsetALMA, offsetSigma) : 
        basisType == 'TEMA' ? ta.tema(close, basisLen) : 
        ta.hma(close, basisLen)

// Signal detection
longSignalXXX = ta.crossover(close, basis) and mcBull
shortSignalXXX = ta.crossunder(close, basis) and mcBear

// ============================================
// RISK MANAGEMENT
// ============================================
atrSLMult = input.float(1.5, "ATR Multiplier for SL", step = 0.1, group = G_RISK)
atrTP1Mult = input.float(1.0, "ATR Multiplier for TP1", step = 0.1, group = G_RISK)
atrTP2Mult = input.float(2.0, "ATR Multiplier for TP2", step = 0.1, group = G_RISK)
atrTP3Mult = input.float(3.0, "ATR Multiplier for TP3", step = 0.1, group = G_RISK)

// Calculate levels
longSL = close - (atr * atrSLMult)
longTP1 = close + (atr * atrTP1Mult)
longTP2 = close + (atr * atrTP2Mult)
longTP3 = close + (atr * atrTP3Mult)

shortSL = close + (atr * atrSLMult)
shortTP1 = close - (atr * atrTP1Mult)
shortTP2 = close - (atr * atrTP2Mult)
shortTP3 = close - (atr * atrTP3Mult)

// ============================================
// STRATEGY EXECUTION
// ============================================
inLong = strategy.position_size > 0
inShort = strategy.position_size < 0

// Entry with confirmation from both systems
finalLong = longSignalXXX and not inLong and not inShort
finalShort = shortSignalXXX and not inShort and not inLong

if finalLong
    strategy.entry("Long", strategy.long)
    strategy.exit("Long Exit", "Long", stop = longSL, limit = longTP3)

if finalShort
    strategy.entry("Short", strategy.short)
    strategy.exit("Short Exit", "Short", stop = shortSL, limit = shortTP3)

// ============================================
// PLOTTING
// ============================================
plot(basis, "MA Basis", color=color.new(color.orange, 0), linewidth=2)

plotshape(finalLong, title="Long Entry", location=location.belowbar, color=color.green, style=shape.triangleup, size=size.normal, text="LONG")
plotshape(finalShort, title="Short Entry", location=location.abovebar, color=color.red, style=shape.triangledown, size=size.normal, text="SHORT")

// Background color
bgcolor(finalLong ? color.new(color.green, 90) : finalShort ? color.new(color.red, 90) : na, title="Signal BG")

// ============================================
// MASTER COACH DASHBOARD
// ============================================
var table dash = table.new("bottom_right", 2, 10, frame_color = color.gray, frame_width = 1, bgcolor = color.new(chart.bg_color, 10))

if barstate.islast
    table.cell(dash, 0, 0, "MC+XXX FUSION", text_color = color.white, bgcolor = color.new(color.purple, 80))
    table.merge_cells(dash, 0, 0, 1, 0)
    
    signalText = finalLong ? "🟢 LONG" : finalShort ? "🔴 SHORT" : "⏳ WAIT"
    signalColor = finalLong ? color.green : finalShort ? color.red : color.gray
    
    table.cell(dash, 0, 1, "Signal", text_color = color.white, text_halign = text.align_left)
    table.cell(dash, 1, 1, signalText, text_color = signalColor, text_halign = text.align_right)
    
    table.cell(dash, 0, 2, "MC Grade", text_color = color.white, text_halign = text.align_left)
    table.cell(dash, 1, 2, mcBull ? str.tostring(bullGrade) + "/6 BULL" : mcBear ? str.tostring(bearGrade) + "/6 BEAR" : "NEUTRAL", 
     text_color = mcBull ? color.green : mcBear ? color.red : color.gray, text_halign = text.align_right)
    
    table.cell(dash, 0, 3, "Structure", text_color = color.white, text_halign = text.align_left)
    table.cell(dash, 1, 3, structBull ? "BULLISH" : "BEARISH", 
     text_color = structBull ? color.green : color.red, text_halign = text.align_right)
    
    table.cell(dash, 0, 4, "MFI", text_color = color.white, text_halign = text.align_left)
    table.cell(dash, 1, 4, mfiBull ? "INFLOW" : "OUTFLOW", 
     text_color = mfiBull ? color.green : color.red, text_halign = text.align_right)
    
    table.cell(dash, 0, 5, "RSI", text_color = color.white, text_halign = text.align_left)
    table.cell(dash, 1, 5, rsiBull ? "BULLISH" : "BEARISH", 
     text_color = rsiBull ? color.green : color.red, text_halign = text.align_right)
    
    table.cell(dash, 0, 6, "Volume", text_color = color.white, text_halign = text.align_left)
    table.cell(dash, 1, 6, volBull ? "HIGH" : "LOW", 
     text_color = volBull ? color.green : color.gray, text_halign = text.align_right)
    
    table.cell(dash, 0, 7, "ATR", text_color = color.white, text_halign = text.align_left)
    table.cell(dash, 1, 7, str.tostring(atr, format.mintick), text_color = color.white, text_halign = text.align_right)
    
    table.cell(dash, 0, 8, "Entry", text_color = color.white, text_halign = text.align_left)
    table.cell(dash, 1, 8, str.tostring(close, format.mintick), text_color = color.yellow, text_halign = text.align_right)
    
    table.cell(dash, 0, 9, "v6.0 | MC+XXX Fusion", text_color = color.gray, text_size = size.tiny)
    table.merge_cells(dash, 0, 9, 1, 9)

// ============================================
// ALERTS
// ============================================
alertMsgLong = "🛢️ USOIL LONG\n\n" +
               "Entry: " + str.tostring(close, format.mintick) + "\n" +
               "SL: " + str.tostring(longSL, format.mintick) + "\n" +
               "TP1: " + str.tostring(longTP1, format.mintick) + "\n" +
               "TP2: " + str.tostring(longTP2, format.mintick) + "\n" +
               "TP3: " + str.tostring(longTP3, format.mintick) + "\n\n" +
               "MC Grade: " + str.tostring(bullGrade) + "/6\n" +
               "Time: " + str.tostring(hour, "00") + ":" + str.tostring(minute, "00")

alertMsgShort = "🛢️ USOIL SHORT\n\n" +
                "Entry: " + str.tostring(close, format.mintick) + "\n" +
                "SL: " + str.tostring(shortSL, format.mintick) + "\n" +
                "TP1: " + str.tostring(shortTP1, format.mintick) + "\n" +
                "TP2: " + str.tostring(shortTP2, format.mintick) + "\n" +
                "TP3: " + str.tostring(shortTP3, format.mintick) + "\n\n" +
                "MC Grade: " + str.tostring(bearGrade) + "/6\n" +
                "Time: " + str.tostring(hour, "00") + ":" + str.tostring(minute, "00")

alertcondition(finalLong, title="🟢 Long Signal", message=alertMsgLong)
alertcondition(finalShort, title="🔴 Short Signal", message=alertMsgShort)

// Auto alerts
if finalLong
    alert(alertMsgLong, alert.freq_once_per_bar_close)

if finalShort
    alert(alertMsgShort, alert.freq_once_per_bar_close)
